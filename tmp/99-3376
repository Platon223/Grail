// The visual result shows literal "[7m>[27m" because the ESC (\033) byte
// is being stripped or escaped before it reaches the terminal. In this
// code we inject raw ANSI escape sequences (cursorStart := "\033[7m",
// cursorEnd := "\033[27m") into the body text prior to calling the
// markdown renderer (m.renderer.Render). Many markdown/HTML renderers and
// sanitizers will remove or neutralize non-printable control bytes such as
// ESC, leaving only the bracketed SGR codes (e.g. "[7m") which then render
// literally in the terminal.
//
// How to fix:
// 1) Apply the cursor/ANSI styling after the renderer has produced its
//    final output. In other words, call m.renderer.Render(visibleBody)
//    first, then split the returned string into lines and inject the
//    ANSI cursor escape sequences into the rendered text. This avoids the
//    renderer sanitizing the ESC bytes.
//
// 2) Prefer using the terminal styling helpers (lipgloss/termenv) instead
//    of embedding raw "\033[...]" sequences. Those libraries produce
//    correct ANSI and play nicer with other formatting and may avoid
//    accidental sanitization if you render after applying styles.
//
// 3) If you must style before rendering, configure the markdown renderer
//    to allow raw ANSI/control bytes (if it supports that) so it doesn't
//    strip ESC. This is less ideal and often renderer-specific.
//
// Implementation notes:
// - When applying styling after rendering, be careful with rune indices
//   (use []rune for multi-byte characters) because byte indices in the
//   rendered output may not match the original body indices.
// - Map the selected cursor position (m.bodyScroll + m.bodyLine and
//   m.bodyCol) to the rendered visible lines, then inject the styling at
//   the correct rune index.
//
// Example (high level):
//   bodyRendered, _ := m.renderer.Render(visibleBody)
//   renderedLines := strings.Split(bodyRendered, "\n")
//   // compute selected line and rune index within renderedLines
//   renderedLines[idx] = renderedLines[idx][:rstart] + cursorStart +
//                       string(runeAt) + cursorEnd + renderedLines[idx][rend:]
//
// The block below is left unchanged; add the fix where the comment
// suggests (apply cursor styling after m.renderer.Render).
if m.item.ID != "" {
    s := ""
    helper, err := m.renderer.Render("`j/k`: scroll - `h/l`: left, right - `r`: reply - `o`: browser - `esc/backspace`: exit")

    if err != nil {
        s += "Error rendering markdown content."
    } else {

        lines := strings.Split(m.item.Body, "\n")

        selectedIdx := m.bodyScroll + m.bodyLine
        if selectedIdx < 0 {
            selectedIdx = 0
        }
        if selectedIdx >= len(lines) {
            selectedIdx = len(lines) - 1
        }

        if m.bodyScroll + m.bodyLine < len(lines) {    
            lines[m.bodyScroll + m.bodyLine] = fmt.Sprintf("%s %s", ">", lines[m.bodyScroll + m.bodyLine])
        }

        currentLine := lines[m.bodyScroll + m.bodyLine]

        if m.bodyCol >= 0 && m.bodyCol < len(currentLine) - 1 {

            cursorStart := "\033[7m"
            cursorEnd   := "\033[27m"

            currentLine = fmt.Sprintf("%s%s%c%s%s", 
                currentLine[:m.bodyCol], 
                cursorStart, 
                currentLine[m.bodyCol], 
                cursorEnd, 
                currentLine[m.bodyCol+1:],
            )

            lines[m.bodyScroll + m.bodyLine] = currentLine
        }

        visibleLines := 50
        end := m.bodyScroll + visibleLines

        if end > len(lines) {
            end = len(lines)
        }

        start := m.bodyScroll
        if start > len(lines) {
            end = len(lines)
        }

        visibleBody := strings.Join(lines[start:end], "\n")

        bodyRendered, err := m.renderer.Render(visibleBody)
        if err != nil {
            bodyRendered = visibleBody
        }

        s += fmt.Sprintf("%s \n\nSubject: %s \nFrom: %s \n\n %s",
            helper,
            m.item.Subject,
            m.item.From,
            bodyRendered,
        )
    }
 
    
    title := titleStyle.Render(" Email View ")
    box := boxStyle.Render(s)
    return fmt.Sprintf("%s\n%s\n", title, box) 
}
