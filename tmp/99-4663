        case "o":
            if m.item.ID != "" && !m.replying {
                // The Gmail web interface expects a user index (e.g. 0) in the /u/<index>/ path.
                // Using the full email address here leads to a 404, so use the primary account index by default.
                // However, if the user wants to open the message in a different account, we can request
                // that account via the `authuser` query parameter. Escape a few common characters so the
                // query param is safer without adding new imports.
                base := "https://mail.google.com/mail/u/0/#all/" + m.item.ID

                if m.userEmail != "" {
                    // Basic escaping for characters that commonly appear in emails and would break a URL.
                    ae := strings.ReplaceAll(m.userEmail, "@", "%40")
                    ae = strings.ReplaceAll(ae, "+", "%2B")
                    ae = strings.ReplaceAll(ae, "&", "%26")
                    ae = strings.ReplaceAll(ae, "?", "%3F")
                    ae = strings.ReplaceAll(ae, "#", "%23")

                    url := base + "?authuser=" + ae
                    auth.OpenBrowser(url)
                } else {
                    auth.OpenBrowser(base)
                }
            }
